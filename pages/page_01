}
DEFAULT_RANGES = {
    "교과서": (1, 30),
    "자습서": (1, 30),
    "문제집": (1, 40),
    "프린트": (1, 8),
}
RESOURCE_COLORS = {
    "교과서": "#e8f1ff",
    "자습서": "#e9f8ef",
    "문제집": "#fff3df",
    "프린트": "#f3eaff",
    "오답": "#ffe9e9",
    "복습": "#eef0f2",
}


def init_state() -> None:
    defaults = {
        "mock_scores": [],
        "wrong_questions": [],
        "study_plan": [],
        "study_materials": {},
    }
    for key, default in defaults.items():
        if key not in st.session_state:
            st.session_state[key] = default.copy() if hasattr(default, "copy") else default

    if not isinstance(st.session_state.mock_scores, list):
        st.session_state.mock_scores = []
    if not isinstance(st.session_state.wrong_questions, list):
        st.session_state.wrong_questions = []
    if not isinstance(st.session_state.study_plan, list):
        st.session_state.study_plan = []
    if not isinstance(st.session_state.study_materials, dict):
        st.session_state.study_materials = {}


def latest_scores() -> Dict[str, float]:
    result = {subject: 70.0 for subject in SUBJECTS}
    records = sorted(st.session_state.mock_scores, key=lambda item: str(item.get("날짜", "")))
    for subject in SUBJECTS:
        values = [
            float(item[subject])
            for item in records
            if isinstance(item.get(subject), (int, float))
        ]
        if values:
            result[subject] = values[-1]
    return result


def unresolved_counts() -> Dict[str, int]:
    result = {subject: 0 for subject in SUBJECTS}
    for item in st.session_state.wrong_questions:
        subject = item.get("과목")
        if subject in result and not bool(item.get("해결", False)):
            result[subject] += 1
    return result


def subject_priorities(selected_subjects: List[str]) -> Dict[str, float]:
    scores = latest_scores()
    wrongs = unresolved_counts()
    return {
        subject: max(1.0, 100.0 - scores[subject] + wrongs[subject] * 4.0)
        for subject in selected_subjects
    }


def choose_block_subjects(selected_subjects: List[str], block_count: int) -> List[str]:
    """약한 과목을 더 자주 배정하되 같은 과목 블록이 바로 이어지지 않게 한다."""
    if not selected_subjects or block_count <= 0:
        return []
    if len(selected_subjects) == 1:
        return [selected_subjects[0]] * block_count

    priorities = subject_priorities(selected_subjects)
    assigned = {subject: 0 for subject in selected_subjects}
    result: List[str] = []
    last_subject = None

    for _ in range(block_count):
        candidates = [subject for subject in selected_subjects if subject != last_subject]
        subject = max(
            candidates,
            key=lambda item: (
                priorities[item] / (assigned[item] + 1),
                priorities[item],
                -SUBJECTS.index(item),
            ),
        )
        result.append(subject)
        assigned[subject] += 1
        last_subject = subject
    return result


def split_range(start: int, end: int, chunk_size: int) -> List[tuple]:
    if start > end:
        return []
    ranges = []
    current = start
    while current <= end:
        last = min(end, current + chunk_size - 1)
        ranges.append((current, last))
        current = last + 1
    return ranges


def task_text(subject: str, unit_name: str, resource: str, first: int, last: int) -> str:
    rule = RESOURCE_RULES[resource]
    range_text = f"{first}{rule['unit']}" if first == last else f"{first}~{last}{rule['unit']}"
    unit_prefix = f"[{unit_name}] " if unit_name.strip() else ""
    return (
        f"{unit_prefix}{resource} {range_text} {rule['action']} "
        f"(약 {rule['minutes']}분)"
    )


def build_resource_queues(subject: str, config: dict) -> Dict[str, List[str]]:
    queues: Dict[str, List[str]] = {resource: [] for resource in RESOURCE_ORDER}
    unit_name = str(config.get("단원", "")).strip()

    for resource in RESOURCE_ORDER:
        item = config.get(resource, {})
        if not bool(item.get("사용", True)):
            continue
        start = int(item.get("시작", 1))
        end = int(item.get("끝", start))
        for first, last in split_range(start, end, RESOURCE_RULES[resource]["chunk"]):
            queues[resource].append(task_text(subject, unit_name, resource, first, last))
    return queues


def build_plan(
    start_date: date,
    end_date: date,
    selected_subjects: List[str],
    tasks_per_day: int,
    consecutive_days: int,
    include_weekends: bool,
    material_configs: Dict[str, dict],
) -> List[dict]:
    study_dates: List[date] = []
    current = start_date
    while current <= end_date:
        if include_weekends or current.weekday() < 5:
            study_dates.append(current)
        current += timedelta(days=1)

    if not study_dates or not selected_subjects:
        return []

    block_count = (len(study_dates) + consecutive_days - 1) // consecutive_days
    block_subjects = choose_block_subjects(selected_subjects, block_count)

    queues = {
        subject: build_resource_queues(subject, material_configs[subject])
        for subject in selected_subjects
    }
    positions = {
        subject: {resource: 0 for resource in RESOURCE_ORDER}
        for subject in selected_subjects
    }
    resource_rotation = {subject: 0 for subject in selected_subjects}
    wrongs = unresolved_counts()
    rows: List[dict] = []

    for index, study_date in enumerate(study_dates):
        subject = block_subjects[index // consecutive_days]
        day_tasks: List[dict] = []
        attempts = 0

        while len(day_tasks) < tasks_per_day and attempts < tasks_per_day * len(RESOURCE_ORDER) * 3:
            resource_index = resource_rotation[subject] % len(RESOURCE_ORDER)
            resource = RESOURCE_ORDER[resource_index]
            resource_rotation[subject] += 1
            attempts += 1

            queue = queues[subject][resource]
            position = positions[subject][resource]
            if position < len(queue):
                day_tasks.append({"자료": resource, "내용": queue[position]})
                positions[subject][resource] += 1

        if len(day_tasks) < tasks_per_day and wrongs.get(subject, 0) > 0:
            remaining = tasks_per_day - len(day_tasks)
            for number in range(remaining):
                count = min(3, wrongs[subject])
                day_tasks.append(
                    {
                        "자료": "오답",
                        "내용": f"{subject} 미해결 오답 {count}문제 다시 풀고, 맞힌 문제는 해결 표시 (약 25분)",
                    }
                )

        while len(day_tasks) < tasks_per_day:
            day_tasks.append(
                {
                    "자료": "복습",
                    "내용": f"{subject} 오늘까지 공부한 범위에서 핵심 개념 5개를 빈 종이에 쓰고 확인 (약 20분)",
                }
            )

        rows.append(
            {
                "날짜": study_date.isoformat(),
                "요일": WEEKDAY_KO[study_date.weekday()],
                "과목": subject,
                "학습내용": day_tasks,
            }
        )
    return rows


def plan_to_csv(rows: List[dict]) -> bytes:
    output = io.StringIO()
    writer = csv.writer(output)
    writer.writerow(["날짜", "요일", "과목", "자료1", "할 일1", "자료2", "할 일2", "자료3", "할 일3", "자료4", "할 일4"])
    for row in rows:
        tasks = list(row.get("학습내용", []))[:4]
        flattened = []
        for task in tasks:
            flattened.extend([task.get("자료", ""), task.get("내용", "")])
        flattened.extend([""] * (8 - len(flattened)))
        writer.writerow([row.get("날짜", ""), row.get("요일", ""), row.get("과목", ""), *flattened])
    return output.getvalue().encode("utf-8-sig")


def render_month(year: int, month: int, plan_lookup: Dict[str, dict]) -> None:
    cal = calendar.Calendar(firstweekday=6)
    weeks = cal.monthdatescalendar(year, month)
    header = "".join(f"<th>{day}</th>" for day in ["일", "월", "화", "수", "목", "금", "토"])
    rows_html = []

    for week in weeks:
        cells = []
        for current_date in week:
            in_month = current_date.month == month
            cell_class = "calendar-cell" if in_month else "calendar-cell other-month"
            day_number = str(current_date.day) if in_month else ""
            content = ""
            item = plan_lookup.get(current_date.isoformat())
            if in_month and item:
                subject = html.escape(str(item.get("과목", "")))
                task_parts = []
                for task in item.get("학습내용", []):
                    resource = html.escape(str(task.get("자료", "")))
                    text = html.escape(str(task.get("내용", "")))
                    color = RESOURCE_COLORS.get(task.get("자료", ""), "#eef0f2")
                    task_parts.append(
                        f'<div class="task"><span class="resource" style="background:{color}">{resource}</span>{text}</div>'
                    )
                content = f'<div class="subject">{subject}</div>{"".join(task_parts)}'
            cells.append(f'<td class="{cell_class}"><div class="day-number">{day_number}</div>{content}</td>')
        rows_html.append("<tr>" + "".join(cells) + "</tr>")

    st.markdown(f"### {year}년 {month}월")
    st.markdown(
        f"""
        <div class="calendar-scroll">
        <table class="calendar-table">
            <thead><tr>{header}</tr></thead>
            <tbody>{''.join(rows_html)}</tbody>
        </table>
        </div>
        """,
        unsafe_allow_html=True,
    )


def render_detailed_list(plan: List[dict]) -> None:
    st.subheader("날짜별 상세 할 일")
    for item in plan:
        with st.container(border=True):
            st.markdown(f"**{item['날짜']} ({item['요일']}) · {item['과목']}**")
            for task in item.get("학습내용", []):
                st.write(f"- **{task.get('자료', '')}**: {task.get('내용', '')}")


init_state()
