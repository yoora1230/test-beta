RESOURCE_RULES = {
    "교과서": {"chunk": 6, "unit": "쪽", "minutes": 25, "action": "읽고 핵심 개념 3개 표시"},
    "자습서": {"chunk": 5, "unit": "쪽", "minutes": 30, "action": "개념 설명을 확인하고 예제까지 풀기"},
