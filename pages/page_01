st.subheader("1. 기본 설정")
col1, col2, col3 = st.columns(3)
with col1:
    start_date = st.date_input("계획 시작일", value=date.today(), key="plan_start")
    end_date = st.date_input("계획 종료일", value=date.today() + timedelta(days=27), key="plan_end")
with col2:
    selected_subjects = st.multiselect(
        "공부할 과목",
        SUBJECTS,
        default=SUBJECTS,
        key="plan_subjects",
    )
    tasks_per_day = st.slider("하루 학습 항목 수", 1, 4, 3, key="plan_tasks_per_day")
with col3:
    consecutive_days = st.slider("한 과목 연속 학습일", 1, 7, 3, key="plan_consecutive_days")
    include_weekends = st.checkbox("주말도 공부", value=True, key="plan_include_weekends")

st.subheader("2. 과목별 시험 범위")
st.caption("실제 시험 범위에 맞게 시작·끝 번호를 바꾸세요. 프린트는 페이지 대신 프린트 번호로 입력합니다.")

material_configs: Dict[str, dict] = {}
for subject in selected_subjects:
    saved = st.session_state.study_materials.get(subject, {})
    with st.expander(f"{subject} 범위 설정", expanded=(subject == selected_subjects[0])):
        unit_name = st.text_input(
            "단원/범위 이름",
            value=str(saved.get("단원", "시험 범위")),
            key=f"unit_{subject}",
            placeholder="예: 2단원 함수 ~ 3단원 경우의 수",
        )
        resource_columns = st.columns(4)
        subject_config = {"단원": unit_name}
        for index, resource in enumerate(RESOURCE_ORDER):
            with resource_columns[index]:
                previous = saved.get(resource, {})
                default_start, default_end = DEFAULT_RANGES[resource]
                enabled = st.checkbox(
                    f"{resource} 사용",
                    value=bool(previous.get("사용", True)),
                    key=f"enabled_{subject}_{resource}",
                )
                start_value = st.number_input(
                    f"{resource} 시작",
                    min_value=1,
                    max_value=9999,
                    value=int(previous.get("시작", default_start)),
                    step=1,
                    key=f"start_{subject}_{resource}",
                )
                end_value = st.number_input(
                    f"{resource} 끝",
                    min_value=1,
                    max_value=9999,
                    value=int(previous.get("끝", default_end)),
                    step=1,
                    key=f"end_{subject}_{resource}",
                )
                subject_config[resource] = {
                    "사용": enabled,
                    "시작": int(start_value),
                    "끝": int(end_value),
                }
        material_configs[subject] = subject_config

create_plan = st.button("계획표 만들기", type="primary", use_container_width=True)

if create_plan:
    errors = []
    if end_date < start_date:
        errors.append("종료일은 시작일보다 빠를 수 없습니다.")
    if not selected_subjects:
        errors.append("과목을 하나 이상 선택하세요.")
    for subject, config in material_configs.items():
        active_resources = 0
        for resource in RESOURCE_ORDER:
            item = config[resource]
            if item["사용"]:
                active_resources += 1
                if item["시작"] > item["끝"]:
                    errors.append(f"{subject} {resource}의 시작 번호가 끝 번호보다 큽니다.")
        if active_resources == 0:
            errors.append(f"{subject}에서 사용할 자료를 하나 이상 선택하세요.")

    if errors:
        for message in errors:
            st.error(message)
    else:
        st.session_state.study_materials = material_configs
        st.session_state.study_plan = build_plan(
            start_date=start_date,
            end_date=end_date,
            selected_subjects=selected_subjects,
            tasks_per_day=tasks_per_day,
            consecutive_days=consecutive_days,
            include_weekends=include_weekends,
            material_configs=material_configs,
        )
        st.success("교재별 범위를 날짜별로 나눈 계획표를 만들었습니다.")

plan = st.session_state.study_plan
if plan:
    st.divider()
    plan_lookup = {item["날짜"]: item for item in plan}
    first = date.fromisoformat(plan[0]["날짜"])
    last = date.fromisoformat(plan[-1]["날짜"])

    year, month = first.year, first.month
    while (year, month) <= (last.year, last.month):
        render_month(year, month, plan_lookup)
        if month == 12:
            year, month = year + 1, 1
        else:
            month += 1

    st.download_button(
        "계획표 CSV 다운로드",
        data=plan_to_csv(plan),
        file_name="시험_계획표_상세.csv",
        mime="text/csv",
        use_container_width=True,
    )
    render_detailed_list(plan)
else:
    st.info("기본 설정과 과목별 범위를 입력한 뒤 계획표 만들기를 누르세요.")
